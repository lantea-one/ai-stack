## We'll need a server for service DNS over IPv4 and IPv6. This is the default
## configuration for the stack, but you can change it if you want to.
STACK_DNS_IPV4_1=9.9.9.11
STACK_DNS_IPV4_2=149.112.112.11
STACK_DNS_IPV6_1=2620:fe::11
STACK_DNS_IPV6_2=2620:fe::fe:11

## Define the startup timeout for the stack's image service. This will determine how
## long Docker will wait for the image service to start before considering it failed.
STACK_IMAGE_STARTUP_TIMEOUT=10m

## Define our stack key, which will be used as a prefix for all environment variables related to the stack.
## This will allow us to easily identify and manage the environment variables for the stack, and also allow
## us to run multiple stacks on the same machine without conflicts by using different prefixes for each stack.
## The default is 'ai', but you can change this to your desired prefix if you want to. Just make sure to update
## the other environment variables accordingly to use the new prefix if you change it.
STACK_KEY='ai'

## Define the domain for the stack. This will be used to create the network for the stack and to define the host names
## for the services in the stack. The default is "${STACK_KEY}.local", but you can change this to your desired domain
## if you want to. Just make sure to update the other environment variables accordingly to use the new domain if you
## change it. This domain will be used for service discovery within the stack, so it's important to choose a unique
## domain that won't conflict with other services on your network. By using a domain like "${STACK_KEY}.local", we can
## ensure that the services in the stack can easily discover each other using their host names (e.g.,
## "service1.${STACK_DOMAIN}", "service2.${STACK_DOMAIN}", etc.) without conflicts with other services on the network.
STACK_DOMAIN="${STACK_KEY}.local"

## Define the name of our stack.
STACK_NAME="${STACK_KEY}-stack"

## Define the username for Portainer. This will be used to set the username for the Portainer service in the stack.
## This cannot be changed through the environment variable, therefore changing this value has no effect on the stack.
STACK_PORTAINER_USERNAME=admin

## Define our password for Portainer. This will be used to set the password for the Portainer service in the stack.
## The default is a randomly generated 32-character base64 string, but you can change this to your desired password
## if you want to. Just make sure to update the other environment variables accordingly to use the new password if
## you change it.
STACK_PORTAINER_PASSWORD='ChangeMe123!!!$'

## Define the HTTP and HTTPS ports for Portainer. These will be used to set the ports for the Portainer service in the
## stack. The default HTTP port is 9000 and the default HTTPS port is 9443, but you can change these to your desired
## ports if you want to. Just make sure to update the other environment variables accordingly to use the new ports if
## you change them. Also, make sure that the ports you choose are not already in use by other services on your machine,
## and that they are properly forwarded if you are running the stack on a remote server. The HTTP port will be used to
## access the Portainer web interface, while the HTTPS port will be used for secure access to the Portainer web
## interface. It's important to choose secure ports for these services, especially if you are exposing them to the
## internet, to prevent unauthorized access to your stack's management interface.
STACK_PORTAINER_PORT_HTTP="9000"
STACK_PORTAINER_PORT_HTTPS="9443"

## Define the stack's restart policy. This will determine how the stack's services are restarted if they fail.
STACK_RESTART_POLICY=unless-stopped

## Define our IPv4 and IPv6 subnets for the stack. These will be used to create the network for the stack.
STACK_SUBNET_IPV4=172.16.13
STACK_SUBNET_IPV6=fdd0:172:16:13

## Define the timezone for the stack. This will be used by the services in the stack to set their timezone.
## The default is "America/New_York", but you can change this to your desired timezone if you want to.
STACK_TIMEZONE=America/New_York

## Define the list of language models to load into Ollama. This should be a comma-separated list of model names and
## their corresponding sizes, in the format "model_name:model_size". For example,
## "gemma3:4b,qwen2.5-coder:7b,codegemma:2b". The default is "gemma3:4b,qwen2.5-coder:7b,codegemma:2b", but you can
## change this to your desired list of models if you want to.
STACK_OLLAMA_DEFAULT_MODEL=gemma3:4b
STACK_OLLAMA_MODEL_LIST=gemma3:4b,qwen2.5-coder:7b,codegemma:2b

## Define the list of image generation models to load into the image service. This should be a comma-separated list of
## model names. For example, "DreamShaper_8_pruned.safetensors". The default is "Lykon/dreamshaper-xl-lightning", but
## you can change this to your desired list of models if you want to. Just make sure to update the other environment
## variables accordingly to use the new list of models if you change it.
STACK_SDNEXT_MODEL_LIST="https://huggingface.co/Lykon/dreamshaper-xl-lightning/resolve/main/DreamShaperXL_Lightning-SFW.safetensors"
STACK_SDNEXT_MODEL_PATH="/mnt/models/Stable-diffusion"

## Define the administrator credentials for the AI frontend service. These will be used to set the administrator email,
## password, and name for the AI frontend service. The default email is "admin@${STACK_DOMAIN}", the default password
## is a randomly generated 32-character base64 string, and the default name is "System Administrator". You can change
## these to your desired values if you want to. Just make sure to update the other environment variables accordingly
## to use the new values if you change them. The administrator credentials are important for accessing the AI frontend
## service and managing the stack, so it's important to choose secure values for these credentials.
STACK_FRONTEND_WEBUI_ADMIN_EMAIL="admin@${STACK_DOMAIN}"
STACK_FRONTEND_WEBUI_ADMIN_PASSWORD="ChangeMe123!!!$"
STACK_FRONTEND_WEBUI_ADMIN_NAME="System Administrator"

## Define the HTTP port for the AI frontend service. This will be used to set the HTTP port for the AI frontend service
## in the stack. The default is 8080, but you can change this to your desired port if you want to. Just make sure to
## update the other environment variables accordingly to use the new port if you change it. Also, make sure that the
## port you choose is not already in use by other services on your machine, and that it is properly forwarded if you
## are running the stack on a remote server. The HTTP port will be used to access the AI frontend web interface, so
## it's important to choose a secure port for this service, especially if you are exposing it to the internet, to
## prevent unauthorized access to your stack's AI frontend interface.
STACK_FRONTEND_PORT_HTTP="8080"

## Define the web secret for the AI frontend service.
STACK_FRONTEND_WEBUI_SECRET_KEY="SomeVeryLongSuperSecretAndRandomStringThatShouldBeChanged"

#######################################################################################################################
### GPU Configurations ################################################################################################
#######################################################################################################################

## These are the default arguments to pass to the SDNext service when it starts. These will be used to set the command
## for the SDNext service in the stack. The default is "--api --listen", which will start the SDNext service in API
## mode and listen for incoming requests. You can change this to your desired arguments if you want to. Just make sure
## to update the other environment variables accordingly to use the new arguments if you change them. The
## SDNext_ARGUMENT_LIST variable will be used to set the command for the SDNext service in the stack, so it's important
## to choose the appropriate arguments for your desired configuration and use case. For example, if you want to start
## the SDNext service in a different mode or with different settings, you can change the arguments accordingly to
## achieve the desired behavior for the SDNext service in your stack.
STACK_SDNEXT_ARGUMENT_LIST='--api --listen'

## Below are the default GPU configurations for the stack. These are used to configure the Ollama and SDNext services
## to use the appropriate GPU device and settings for your system. You can change these values to match your desired
## GPU configuration if you want to. Just make sure to update the other environment variables accordingly to use the
## new values if you change them. The default values are set to use an Intel Arc GPU device with flash attention
## enabled, a maximum of 3 loaded models, 4096 context size, 1 parallel model, and the appropriate oneAPI device
## selector and sysman settings. If you are using a different GPU device, such as an Intel Iris, nVidia CUDA, or AMD
## ROCm device, you can change the values accordingly to match your desired configuration. The SDNext model list is
## also set to use the appropriate model for the selected GPU device. Make sure to choose the appropriate GPU
## configuration for your system to ensure optimal performance and compatibility with the stack's services.

## Intel Arc (IPEX)
GPU_INTEL_ARC_AUTOMATIC1111_CFG_SCALE=1.0
GPU_INTEL_ARC_BACKEND_IMAGE=docker.io/uberchuckie/ollama-intel-gpu:latest
GPU_INTEL_ARC_CUDA_FORCE_ATTENTION_SLICE=0
GPU_INTEL_ARC_CUDA_VISIBLE_DEVICES=
GPU_INTEL_ARC_DEVICE=Arc
GPU_INTEL_ARC_FRONTEND_IMAGE_MODEL=DreamShaperXL_Lightning-SFW.safetensors
GPU_INTEL_ARC_FRONTEND_IMAGE_SIZE=1024x1024
GPU_INTEL_ARC_FRONTEND_IMAGE_STEPS=4
GPU_INTEL_ARC_IMAGE_IMAGE=docker.io/liutyi/sdnext-ipex:master
GPU_INTEL_ARC_IPEX_FORCE_ATTENTION_SLICE=1
GPU_INTEL_ARC_IPEXRUN=true
GPU_INTEL_ARC_OLLAMA_FLASH_ATTENTION=1
GPU_INTEL_ARC_OLLAMA_MAX_LOADED_MODELS=3
GPU_INTEL_ARC_OLLAMA_NUM_CTX=4096
GPU_INTEL_ARC_OLLAMA_NUM_PARALLEL=1
GPU_INTEL_ARC_OLLAMA_ONEAPI_DEVICE_SELECTOR='level_zero:0'
GPU_INTEL_ARC_OLLAMA_ZES_ENABLE_SYSMAN=1
GPU_INTEL_ARC_SDNEXT_ARGUMENT_LIST='--use-ipex'
GPU_INTEL_ARC_SDNEXT_MODEL_LIST=

## Intel Iris (Integrated Graphics)
GPU_INTEL_IRIS_AUTOMATIC1111_CFG_SCALE=1.0
GPU_INTEL_IRIS_BACKEND_IMAGE=docker.io/uberchuckie/ollama-intel-gpu:latest
GPU_INTEL_IRIS_CUDA_FORCE_ATTENTION_SLICE=0
GPU_INTEL_IRIS_CUDA_VISIBLE_DEVICES=
GPU_INTEL_IRIS_DEVICE=iGPU
GPU_INTEL_IRIS_FRONTEND_IMAGE_MODEL=DreamShaper8_LCM.safetensors
GPU_INTEL_IRIS_FRONTEND_IMAGE_SIZE=512x512
GPU_INTEL_IRIS_FRONTEND_IMAGE_STEPS=6
GPU_INTEL_IRIS_IMAGE_IMAGE=docker.io/liutyi/sdnext-ipex:master
GPU_INTEL_IRIS_IPEX_FORCE_ATTENTION_SLICE=1
GPU_INTEL_IRIS_IPEXRUN=true
GPU_INTEL_IRIS_OLLAMA_FLASH_ATTENTION=1
GPU_INTEL_IRIS_OLLAMA_MAX_LOADED_MODELS=1
GPU_INTEL_IRIS_OLLAMA_NUM_CTX=2048
GPU_INTEL_IRIS_OLLAMA_NUM_PARALLEL=1
GPU_INTEL_IRIS_OLLAMA_ONEAPI_DEVICE_SELECTOR='level_zero:1'
GPU_INTEL_IRIS_OLLAMA_ZES_ENABLE_SYSMAN=1
GPU_INTEL_IRIS_SDNEXT_ARGUMENT_LIST='--lowvram --use-ipex'
GPU_INTEL_IRIS_SDNEXT_MODEL_LIST='https://huggingface.co/Lykon/dreamshaper-8-lcm/resolve/main/DreamShaper8_LCM.safetensors'

## nVidia (CUDA)
GPU_NVIDIA_AUTOMATIC1111_CFG_SCALE=2.0
GPU_NVIDIA_BACKEND_IMAGE=docker.io/ollama/ollama:latest
GPU_NVIDIA_DEVICE=cuda
GPU_NVIDIA_CUDA_FORCE_ATTENTION_SLICE=1
GPU_NVIDIA_CUDA_VISIBLE_DEVICES=0
GPU_NVIDIA_FRONTEND_IMAGE_MODEL=DreamShaperXL_Lightning-SFW.safetensors
GPU_NVIDIA_FRONTEND_IMAGE_SIZE=1024x1024
GPU_NVIDIA_FRONTEND_IMAGE_STEPS=4
GPU_NVIDIA_IMAGE_IMAGE=docker.io/vladmandic/sdnext-cuda:latest
GPU_NVIDIA_IPEX_FORCE_ATTENTION_SLICE=0
GPU_NVIDIA_IPEXRUN=false
GPU_NVIDIA_OLLAMA_FLASH_ATTENTION=1
GPU_NVIDIA_OLLAMA_MAX_LOADED_MODELS=3
GPU_NVIDIA_OLLAMA_NUM_CTX=4096
GPU_NVIDIA_OLLAMA_NUM_PARALLEL=1
GPU_NVIDIA_OLLAMA_ONEAPI_DEVICE_SELECTOR=
GPU_NVIDIA_OLLAMA_ZES_ENABLE_SYSMAN=1
GPU_NVIDIA_SDNEXT_ARGUMENT_LIST='--use-cuda'
GPU_NVIDIA_SDNEXT_MODEL_LIST=

## AMD (ROCm)
GPU_AMD_AUTOMATIC1111_CFG_SCALE=2.0
GPU_AMD_BACKEND_IMAGE=docker.io/ollama/ollama:latest
GPU_AMD_CUDA_FORCE_ATTENTION_SLICE=0
GPU_AMD_CUDA_VISIBLE_DEVICES=
GPU_AMD_DEVICE=rocm
GPU_AMD_FRONTEND_IMAGE_MODEL=DreamShaperXL_Lightning-SFW.safetensors
GPU_AMD_FRONTEND_IMAGE_SIZE=1024x1024
GPU_AMD_FRONTEND_IMAGE_STEPS=4
GPU_AMD_IMAGE_IMAGE=docker.io/vladmandic/sdnext-rocm:latest
GPU_AMD_IPEX_FORCE_ATTENTION_SLICE=0
GPU_AMD_IPEXRUN=false
GPU_AMD_OLLAMA_FLASH_ATTENTION=1
GPU_AMD_OLLAMA_MAX_LOADED_MODELS=3
GPU_AMD_OLLAMA_NUM_CTX=4096
GPU_AMD_OLLAMA_NUM_PARALLEL=1
GPU_AMD_OLLAMA_ONEAPI_DEVICE_SELECTOR=
GPU_AMD_OLLAMA_ZES_ENABLE_SYSMAN=1
GPU_AMD_SDNEXT_ARGUMENT_LIST='--use-rocm'
GPU_AMD_SDNEXT_MODEL_LIST=
